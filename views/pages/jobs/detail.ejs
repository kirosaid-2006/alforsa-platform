<div class="two-col-layout">
    <!-- Main Job Content -->
    <div>
        <div style="background: white; border-radius: var(--radius); border: 1px solid var(--border); padding: 2rem; margin-bottom: 1.5rem;">
            <div style="display: flex; gap: 1.5rem; margin-bottom: 2rem; align-items: flex-start;">
                <div class="job-logo" style="width: 80px; height: 80px; font-size: 2rem;">
                    <%= job.company_name ? job.company_name.substring(0, 1) : 'ش' %>
                </div>
                <div style="flex: 1;">
                    <h1 style="font-size: 1.75rem; margin-bottom: 0.5rem;"><%= job.title %></h1>
                    <div style="font-size: 1.1rem; color: var(--text-secondary); margin-bottom: 1rem;">
                        🏢 <%= job.company_name %>
                    </div>
                    <div class="job-meta" style="font-size: 1rem;">
                        <% if (job.governorate) { %><span>📍 <%= job.governorate.name %> <% if (job.city) { %> - <%= job.city %> <% } %></span><% } %>
                        <span>🕒 نُشرت في: <%= new Date(job.published_at || job.createdAt).toLocaleDateString('ar-EG') %></span>
                        <span>👁️ المشاهدات: <%= job.views_count || 0 %></span>
                    </div>
                </div>
            </div>

            <hr style="border: none; border-top: 1px solid var(--border); margin: 2rem 0;">

            <% if (job.image_url) { %>
            <div style="margin-bottom: 2rem; text-align: center;">
                <img src="<%= job.image_url %>" alt="صورة إعلان الوظيفة" style="max-width: 100%; max-height: 500px; border-radius: var(--radius); border: 1px solid var(--border); box-shadow: var(--shadow-sm);">
            </div>
            <% } %>

            <div style="margin-bottom: 2rem;">
                <h3 style="color: var(--primary); margin-bottom: 1rem;">وصف الوظيفة</h3>
                <div style="white-space: pre-line; color: var(--text-secondary);">
                    <%= job.description %>
                </div>
            </div>

            <% if (job.requirements) { %>
            <div style="margin-bottom: 2rem;">
                <h3 style="color: var(--primary); margin-bottom: 1rem;">متطلبات الوظيفة</h3>
                <div style="white-space: pre-line; color: var(--text-secondary);">
                    <%= job.requirements %>
                </div>
            </div>
            <% } %>

            <div style="background: var(--bg-body); padding: 1.5rem; border-radius: var(--radius-sm); display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1.5rem; margin-bottom: 2rem;">
                <div>
                    <strong>الراتب:</strong><br>
                    <span style="color: var(--success); font-weight: 700;">
                        <% if (job.show_salary && (job.salary_min || job.salary_max)) { %>
                            <%= job.salary_min || 0 %> - <%= job.salary_max || 'غير محدد' %> ج.م
                        <% } else { %>
                            يحدد بالمقابلة
                        <% } %>
                    </span>
                </div>
                <div>
                    <strong>المؤهل المطلوب:</strong><br>
                    <span>
                        <% if(job.qualification === 'none') { %> بدون مؤهل
                        <% } else if(job.qualification === 'diploma') { %> دبلوم / مؤهل متوسط
                        <% } else if(job.qualification === 'institute') { %> معهد / فوق متوسط
                        <% } else if(job.qualification === 'bachelors') { %> بكالوريوس / ليسانس
                        <% } else { %> غير محدد <% } %>
                    </span>
                </div>
                <div>
                    <strong>الخبرة المطلوبة:</strong><br>
                    <span>
                        <% if(job.min_experience_years === 0) { %> بدون خبرة
                        <% } else if(job.min_experience_years) { %> <%= job.min_experience_years %> سنوات فأكثر
                        <% } else { %> غير محدد <% } %>
                    </span>
                </div>
                <div>
                    <strong>ساعات العمل:</strong><br>
                    <span><%= job.working_hours ? job.working_hours : 'غير محدد' %></span>
                </div>
            </div>

            <!-- Apply & Contact Section -->
            <div style="text-align: center; margin-top: 3rem;">
                <% if (locals.user && locals.hasApplied) { %>
                    <!-- User already applied -->
                    <div class="alert-banner" style="background: var(--success); margin-bottom: 1.5rem;">
                        ✅ لقد تقدمت لهذه الوظيفة مسبقاً! يمكنك التواصل مع الشركة عبر البيانات أدناه.
                    </div>
                    
                    <div style="background: var(--primary-light); padding: 2rem; border-radius: var(--radius); border: 1px solid var(--primary);">
                        <h3 style="color: var(--primary-text); margin-bottom: 1.5rem;">بيانات التواصل مع الشركة</h3>
                        <div style="display: flex; flex-direction: column; gap: 1rem; font-size: 1.2rem; align-items: center;">
                            <% if (job.contact_phone) { %>
                                <div>📞 رقم الهاتف: <a href="tel:<%= job.contact_phone %>" style="font-weight: 700; color: var(--primary); text-decoration: underline;"><strong><%= job.contact_phone %></strong></a></div>
                            <% } %>
                            <% if (job.contact_whatsapp) { %>
                                <div>💬 واتساب: <a href="https://wa.me/2<%= job.contact_whatsapp %>" target="_blank" style="font-weight: 700; color: #25D366; text-decoration: underline;"><%= job.contact_whatsapp %></a></div>
                            <% } %>
                            <% if (job.contact_email) { %>
                                <div>📧 البريد الإلكتروني: <a href="mailto:<%= job.contact_email %>" style="font-weight: 700; color: var(--primary); text-decoration: underline;"><strong><%= job.contact_email %></strong></a></div>
                            <% } %>
                            <% if (job.contact_info) { %>
                                <div style="margin-top: 1rem; font-size: 1rem; color: var(--text-secondary);"><%= job.contact_info %></div>
                            <% } %>
                        </div>
                    </div>
                <% } else { %>
                    <!-- User needs to apply to reveal -->
                    <input type="hidden" id="job-slug" value="<%= job.slug %>">
                    <button id="btn-apply-reveal" data-job-id="<%= job.id %>" class="btn btn-primary" style="font-size: 1.25rem; padding: 1rem 3rem;">
                        تقديم والحصول على بيانات التواصل
                    </button>
                    <p style="margin-top: 1rem; font-size: 0.9rem;">بضغطك على هذا الزر، ستتمكن من رؤية أرقام هواتف الشركة للتواصل معهم مباشرة.</p>
                    
                    <!-- Hidden Contact Section (revealed via JS AJAX) -->
                    <div id="contact-info-section" style="display: none; background: var(--primary-light); padding: 2rem; border-radius: var(--radius); border: 1px solid var(--primary); margin-top: 2rem;">
                        <h3 style="color: var(--primary-text); margin-bottom: 1.5rem;">بيانات التواصل مع الشركة</h3>
                        <div style="display: flex; flex-direction: column; gap: 1rem; font-size: 1.2rem; align-items: center;">
                            <div>📞 رقم الهاتف: <a href="#" id="c-phone" style="font-weight: 700; color: var(--primary); text-decoration: underline;">غير متوفر</a></div>
                            <div>💬 واتساب: <a id="c-whatsapp" href="#" target="_blank" style="font-weight: 700; color: #25D366; text-decoration: underline;">غير متوفر</a></div>
                            <div>📧 البريد الإلكتروني: <a href="#" id="c-email" style="font-weight: 700; color: var(--primary); text-decoration: underline;">غير متوفر</a></div>
                        </div>
                    </div>
                <% } %>
            </div>
        </div>
    </div>

    <!-- Sidebar -->
    <aside class="sidebar">
        <div class="sidebar-widget text-center">
            <h3>شارك الوظيفة</h3>
            <p style="font-size: 0.9rem;">ساعد أصدقائك في العثور على فرصة عمل!</p>
            <div style="display: flex; gap: 0.5rem; justify-content: center; margin-top: 1rem;">
                <button class="btn btn-outline" onclick="navigator.clipboard.writeText(window.location.href); alert('تم نسخ الرابط!');">🔗 نسخ الرابط</button>
            </div>
        </div>

        <div class="sidebar-widget">
            <h3 style="color: var(--danger);">نصائح هامة ⚠️</h3>
            <ul style="padding-right: 1.2rem; font-size: 0.9rem; color: var(--text-secondary); margin-bottom: 1.5rem;">
                <li style="margin-bottom: 0.5rem;">لا تدفع أي مبالغ مالية مقابل التوظيف.</li>
                <li style="margin-bottom: 0.5rem;">تأكد من عنوان الشركة واسمها أثناء المقابلة.</li>
                <li style="margin-bottom: 0.5rem;">لا تشارك أرقام بطاقتك البنكية أو كلمات السر الخاصة بك.</li>
            </ul>
            
            <div style="border-top: 1px solid var(--border); padding-top: 1rem; text-align: center;">
                <p style="font-size: 0.85rem; color: var(--text-muted); margin-bottom: 0.5rem;">هل يوجد خطأ في الوظيفة؟</p>
                <button onclick="document.getElementById('reportModal').style.display='flex'" class="btn btn-outline" style="color: var(--danger); border-color: var(--danger); width: 100%; font-size: 0.9rem;">
                    🚩 إبلاغ عن الوظيفة
                </button>
            </div>
        </div>
    </aside>
</div>

<!-- Report Modal -->
<div id="reportModal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 1000; align-items: center; justify-content: center; padding: 1rem;">
    <div style="background: white; width: 100%; max-width: 500px; border-radius: var(--radius); padding: 2rem; position: relative;">
        <button onclick="document.getElementById('reportModal').style.display='none'" style="position: absolute; top: 1rem; right: 1rem; background: transparent; border: none; font-size: 1.5rem; cursor: pointer; color: var(--text-muted);">&times;</button>
        <h3 style="margin-bottom: 1rem; color: var(--danger);">🚩 إبلاغ عن وظيفة</h3>
        <p style="font-size: 0.95rem; color: var(--text-secondary); margin-bottom: 1.5rem;">يرجى توضيح سبب البلاغ (مثال: الأرقام غير صحيحة، الوظيفة وهمية، طلب مبالغ مالية).</p>
        
        <textarea id="reportReason" class="form-control" rows="4" placeholder="اكتب سبب البلاغ هنا..."></textarea>
        
        <div style="margin-top: 1.5rem; display: flex; gap: 1rem;">
            <button id="submitReportBtn" class="btn btn-primary" style="flex: 1; background: var(--danger); border-color: var(--danger);">إرسال البلاغ</button>
            <button onclick="document.getElementById('reportModal').style.display='none'" class="btn btn-outline" style="flex: 1;">إلغاء</button>
        </div>
        <div id="reportStatusMessage" style="margin-top: 1rem; font-size: 0.9rem; text-align: center; display: none;"></div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const reportBtn = document.getElementById('submitReportBtn');
        const reasonInput = document.getElementById('reportReason');
        const statusMsg = document.getElementById('reportStatusMessage');
        const jobId = document.getElementById('job-slug') ? document.getElementById('btn-apply-reveal').dataset.jobId : '<%= job.id %>';

        if (reportBtn) {
            reportBtn.addEventListener('click', async () => {
                const reason = reasonInput.value.trim();
                if (!reason) {
                    statusMsg.style.display = 'block';
                    statusMsg.style.color = 'var(--danger)';
                    statusMsg.textContent = 'يرجى كتابة سبب البلاغ أولاً.';
                    return;
                }

                reportBtn.disabled = true;
                reportBtn.textContent = 'جاري الإرسال...';

                try {
                    const response = await fetch(`/jobs/${jobId}/report`, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify({ reason })
                    });

                    const data = await response.json();

                    statusMsg.style.display = 'block';
                    if (response.ok && data.success) {
                        statusMsg.style.color = 'var(--success)';
                        statusMsg.textContent = data.message;
                        reasonInput.value = '';
                        setTimeout(() => {
                            document.getElementById('reportModal').style.display='none';
                            statusMsg.style.display='none';
                            reportBtn.disabled = false;
                            reportBtn.textContent = 'إرسال البلاغ';
                        }, 2500);
                    } else if (response.status === 401) {
                        statusMsg.style.color = 'var(--danger)';
                        statusMsg.innerHTML = 'يجب <a href="/auth/login" style="text-decoration: underline;">تسجيل الدخول</a> للإبلاغ.';
                        reportBtn.disabled = false;
                        reportBtn.textContent = 'إرسال البلاغ';
                    } else {
                        statusMsg.style.color = 'var(--danger)';
                        statusMsg.textContent = data.message || data.error || 'حدث خطأ.';
                        reportBtn.disabled = false;
                        reportBtn.textContent = 'إرسال البلاغ';
                    }
                } catch (err) {
                    statusMsg.style.display = 'block';
                    statusMsg.style.color = 'var(--danger)';
                    statusMsg.textContent = 'حدث خطأ في الاتصال بالسيرفر.';
                    reportBtn.disabled = false;
                    reportBtn.textContent = 'إرسال البلاغ';
                }
            });
        }
    });
</script>
