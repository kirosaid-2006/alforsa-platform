<!-- Admin Navbar -->
<%- include('../../partials/admin-sidebar', { path: '/admin/jobs' }) %>

<div>
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; flex-wrap: wrap; gap: 1rem;">
        <h2>إدارة الوظائف 💼</h2>
        <a href="/admin/jobs/create" class="btn btn-primary" style="padding: 0.5rem 1rem;">➕ إضافة وظيفة جديدة</a>
    </div>


    <!-- Filter Section -->
    <div style="background: white; border: 1px solid var(--border); border-radius: var(--radius); padding: 1.5rem; margin-bottom: 2rem; box-shadow: var(--shadow-sm);">
        <form action="/admin/jobs" method="GET" style="display: flex; gap: 1rem; align-items: flex-end; flex-wrap: wrap;">
            <div style="flex: 1; min-width: 200px;">
                <label class="form-label" style="margin-bottom: 0.5rem;">تصفية بالفئة</label>
                <select name="category_id" class="form-control" style="margin: 0;">
                    <option value="">جميع الفئات</option>
                    <% categories.forEach(cat => { %>
                        <option value="<%= cat.id %>" <%= query.category_id == cat.id ? 'selected' : '' %>><%= cat.name %></option>
                    <% }) %>
                </select>
            </div>
            <div style="flex: 1; min-width: 200px;">
                <label class="form-label" style="margin-bottom: 0.5rem;">حالة الوظيفة</label>
                <select name="status" class="form-control" style="margin: 0;">
                    <option value="">جميع الحالات</option>
                    <option value="published" <%= query.status == 'published' ? 'selected' : '' %>>منشورة</option>
                    <option value="pending" <%= query.status == 'pending' ? 'selected' : '' %>>قيد المراجعة</option>
                    <option value="rejected" <%= query.status == 'rejected' ? 'selected' : '' %>>مرفوضة</option>
                    <option value="closed" <%= query.status == 'closed' ? 'selected' : '' %>>مغلقة</option>
                </select>
            </div>
            <div>
                <button type="submit" class="btn btn-primary" style="padding: 0.75rem 2rem;">🔍 بحث</button>
                <% if (query.category_id || query.status) { %>
                    <a href="/admin/jobs" class="btn btn-outline" style="padding: 0.75rem 1rem;">إلغاء</a>
                <% } %>
            </div>
        </form>
    </div>

    <!-- Jobs Grid -->
    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(350px, 1fr)); gap: 1.5rem;">
        <% if (jobs && jobs.length > 0) { %>
            <% jobs.forEach(job => { %>
                <div style="background: white; border: 1px solid var(--border); border-radius: var(--radius); padding: 1.5rem; box-shadow: var(--shadow-sm); display: flex; flex-direction: column; gap: 1rem; position: relative;">
                    
                    <!-- Status Badge -->
                    <div style="position: absolute; top: 1.5rem; left: 1.5rem;">
                        <% if (job.status === 'published') { %>
                            <span style="background: #d4edda; color: #155724; padding: 0.25rem 0.75rem; border-radius: 50px; font-size: 0.8rem; font-weight: bold;">منشورة</span>
                        <% } else if (job.status === 'pending') { %>
                            <span style="background: #fff3cd; color: #856404; padding: 0.25rem 0.75rem; border-radius: 50px; font-size: 0.8rem; font-weight: bold;">قيد المراجعة</span>
                        <% } else if (job.status === 'rejected') { %>
                            <span style="background: #f8d7da; color: #721c24; padding: 0.25rem 0.75rem; border-radius: 50px; font-size: 0.8rem; font-weight: bold;">مرفوضة</span>
                        <% } else { %>
                            <span style="background: #e2e3e5; color: #383d41; padding: 0.25rem 0.75rem; border-radius: 50px; font-size: 0.8rem; font-weight: bold;">مغلقة</span>
                        <% } %>
                    </div>

                    <!-- Job Info -->
                    <div>
                        <p style="font-size: 0.8rem; color: var(--text-muted); margin-bottom: 0.5rem;"><%= new Date(job.createdAt).toLocaleDateString('ar-EG') %></p>
                        <h3 style="margin: 0 0 0.25rem 0; font-size: 1.2rem;">
                            <a href="/jobs/<%= job.slug %>" target="_blank" style="color: var(--primary); text-decoration: none;"><%= job.title %></a>
                        </h3>
                        <div style="font-size: 0.9rem; color: var(--text-secondary); margin-bottom: 0.5rem;">
                            🏢 <%= job.company_name %> 
                        </div>
                        <div style="display: flex; gap: 1rem; font-size: 0.85rem; color: var(--text-muted);">
                            <span>📁 <%= job.category ? job.category.name : 'بدون فئة' %></span>
                            <span>📍 <%= job.governorate ? job.governorate.name : 'غير محدد' %></span>
                        </div>
                    </div>

                    <!-- Actions -->
                    <div style="display: flex; gap: 0.5rem; margin-top: auto; padding-top: 1rem; border-top: 1px solid var(--border);">
                        <a href="/admin/jobs/<%= job.id %>/edit" class="btn btn-outline" style="flex: 1; text-align: center; padding: 0.5rem;">✏️ تعديل</a>
                        <form action="/admin/jobs/<%= job.id %>/delete" method="POST" style="flex: 1; margin: 0;" onsubmit="return confirm('هل أنت متأكد من حذف هذه الوظيفة نهائياً؟');">
                            <button type="submit" class="btn btn-outline" style="width: 100%; padding: 0.5rem; border-color: var(--danger); color: var(--danger);">🗑️ حذف</button>
                        </form>
                    </div>
                </div>
            <% }) %>
        <% } else { %>
            <div style="grid-column: 1 / -1; text-align: center; padding: 4rem 2rem; background: white; border-radius: var(--radius); border: 1px solid var(--border);">
                <div style="font-size: 3rem; margin-bottom: 1rem;">📭</div>
                <h3 style="color: var(--text-secondary); margin: 0;">لا توجد وظائف مطابقة للبحث</h3>
            </div>
        <% } %>
    </div>
</div>
