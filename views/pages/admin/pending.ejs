<!-- Admin Navbar -->
<%- include('../../partials/admin-sidebar', { path: '/admin/jobs/pending' }) %>

<!-- Main Content -->
<div>
    <h2 style="margin-bottom: 2rem;">وظائف قيد المراجعة ⏳</h2>

    <% if (locals.jobs && jobs.length > 0) { %>
        <div style="display: flex; flex-direction: column; gap: 1.5rem;">
            <% jobs.forEach(job => { %>
                <div style="background: white; border: 1px solid var(--border); border-radius: var(--radius); padding: 1.5rem; box-shadow: var(--shadow-sm); display: flex; flex-direction: column; gap: 1rem;">
                    
                    <div style="display: flex; justify-content: space-between; align-items: flex-start; border-bottom: 1px solid var(--border); padding-bottom: 1rem;">
                        <div>
                            <h3 style="margin-bottom: 0.5rem; font-size: 1.5rem; color: var(--primary);"><%= job.title %></h3>
                            <div style="color: var(--text-secondary); font-size: 1.1rem; display: flex; gap: 1.5rem; align-items: center;">
                                <span>🏢 <strong><%= job.company_name %></strong></span>
                                <span>📍 <%= job.governorate ? job.governorate.name : '' %></span>
                                <span>🗂️ <%= job.category ? job.category.name : '' %></span>
                            </div>
                        </div>
                        <div style="text-align: left;">
                            <span class="badge badge-warning" style="margin-bottom: 0.5rem; display: inline-block;">قيد المراجعة</span><br>
                            <small style="color: var(--text-muted);">بواسطة: <%= job.posted_by_admin ? 'Grok AI (تليجرام)' : 'شركة' %></small>
                        </div>
                    </div>

                    <div style="color: var(--text-primary); line-height: 1.8; font-size: 1.05rem;">
                        <p style="white-space: pre-wrap; margin: 0;"><%= job.description %></p>
                    </div>

                    <div style="display: flex; gap: 2rem; background: var(--bg-body); padding: 1rem; border-radius: var(--radius-sm); align-items: center;">
                        <% if (job.salary) { %>
                            <div><span style="color: var(--text-muted); font-size: 0.9rem;">الراتب:</span> <strong style="color: var(--success);"><%= job.salary %></strong></div>
                        <% } %>
                        <div><span style="color: var(--text-muted); font-size: 0.9rem;">طريقة التواصل:</span> <strong><%= job.contact_info %></strong></div>
                    </div>

                    <div style="display: flex; gap: 1rem; margin-top: 0.5rem; justify-content: flex-end;">
                        <form action="/admin/jobs/<%= job.id %>/reject" method="POST" style="margin: 0;">
                            <button type="submit" class="btn btn-outline" style="border-color: var(--danger); color: var(--danger) !important; padding: 0.75rem 2rem;">رفض وحذف</button>
                        </form>
                        <form action="/admin/jobs/<%= job.id %>/approve" method="POST" style="margin: 0;">
                            <button type="submit" class="btn btn-success" style="padding: 0.75rem 3rem;">الموافقة والنشر</button>
                        </form>
                    </div>

                </div>
            <% }) %>
        </div>
    <% } else { %>
        <div style="background: white; border: 1px solid var(--border); border-radius: var(--radius); padding: 4rem 2rem; text-align: center; box-shadow: var(--shadow-sm);">
            <div style="font-size: 4rem; margin-bottom: 1rem;">✅</div>
            <h3 style="color: var(--text-secondary); margin-bottom: 0.5rem;">لا توجد وظائف معلقة</h3>
            <p style="color: var(--text-muted); font-size: 1.1rem;">لقد قمت بمراجعة جميع الوظائف. سيظهر الذكاء الاصطناعي وظائف جديدة هنا بمجرد سحبها.</p>
        </div>
    <% } %>
</div>
