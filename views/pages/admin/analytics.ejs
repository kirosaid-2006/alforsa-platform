<!-- Admin Navbar -->
<%- include('../../partials/admin-sidebar', { path: '/admin/analytics' }) %>

<!-- Main Content -->
<div>
        <h2 style="margin-bottom: 2rem;">إحصائيات التوظيف والأداء</h2>

        <!-- Key Metrics -->
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1.5rem; margin-bottom: 2rem;">
            <div style="background: white; border: 1px solid var(--border); border-radius: var(--radius); padding: 1.5rem; text-align: center;">
                <div style="font-size: 2.5rem; font-weight: 800; color: var(--primary); margin-bottom: 0.5rem;"><%= locals.totalHired || 0 %></div>
                <div style="color: var(--text-secondary); font-weight: 600;">إجمالي من تم توظيفهم</div>
                <small style="color: var(--text-muted);">بناءً على نتائج الاستبيانات</small>
            </div>
            
            <div style="background: white; border: 1px solid var(--border); border-radius: var(--radius); padding: 1.5rem; text-align: center;">
                <div style="font-size: 2.5rem; font-weight: 800; color: var(--success); margin-bottom: 0.5rem;"><%= locals.platformHired || 0 %></div>
                <div style="color: var(--text-secondary); font-weight: 600;">تم توظيفهم بفضل المنصة</div>
                <small style="color: var(--success);">تأثير مباشر لـ "فرصة"</small>
            </div>
            
            <div style="background: white; border: 1px solid var(--border); border-radius: var(--radius); padding: 1.5rem; text-align: center;">
                <div style="font-size: 2.5rem; font-weight: 800; color: var(--warning); margin-bottom: 0.5rem;"><%= locals.successRate || 0 %>%</div>
                <div style="color: var(--text-secondary); font-weight: 600;">معدل نجاح التوظيف</div>
                <small style="color: var(--text-muted);">(المعينين / إجمالي الردود)</small>
            </div>
        </div>

        <div class="two-col-layout" style="gap: 1.5rem; grid-template-columns: 1fr 1fr; margin-bottom: 2rem;">
            <!-- Top Categories -->
            <div style="background: white; border: 1px solid var(--border); border-radius: var(--radius); padding: 1.5rem;">
                <h3 style="margin-bottom: 1rem; border-bottom: 1px solid var(--border); padding-bottom: 0.5rem;">أكثر التخصصات توظيفاً</h3>
                <% if (locals.topCategories && topCategories.length > 0) { %>
                    <ul style="padding: 0;">
                        <% topCategories.forEach((cat, index) => { %>
                            <li style="display: flex; justify-content: space-between; padding: 0.75rem 0; border-bottom: 1px solid var(--bg-body);">
                                <span><strong style="color: var(--primary); margin-left: 0.5rem;">#<%= index + 1 %></strong> <%= cat.name %></span>
                                <span class="badge badge-success"><%= cat.hired_count %> موظف</span>
                            </li>
                        <% }) %>
                    </ul>
                <% } else { %>
                    <p class="text-muted">لا توجد بيانات كافية بعد.</p>
                <% } %>
            </div>

            <!-- Survey Distribution -->
            <div style="background: white; border: 1px solid var(--border); border-radius: var(--radius); padding: 1.5rem;">
                <h3 style="margin-bottom: 1rem; border-bottom: 1px solid var(--border); padding-bottom: 0.5rem;">توزيع نتائج الاستبيانات</h3>
                <% if (locals.surveyStats) { %>
                    <div style="display: flex; flex-direction: column; gap: 1rem; margin-top: 1rem;">
                        <div>
                            <div style="display: flex; justify-content: space-between; margin-bottom: 0.25rem;">
                                <span>تم التعيين (Hired)</span>
                                <strong><%= surveyStats.hired %>%</strong>
                            </div>
                            <div style="width: 100%; background: var(--bg-body); border-radius: 5px; height: 10px;">
                                <div style="width: <%= surveyStats.hired %>%; background: var(--success); height: 100%; border-radius: 5px;"></div>
                            </div>
                        </div>
                        <div>
                            <div style="display: flex; justify-content: space-between; margin-bottom: 0.25rem;">
                                <span>مرفوض (Rejected)</span>
                                <strong><%= surveyStats.rejected %>%</strong>
                            </div>
                            <div style="width: 100%; background: var(--bg-body); border-radius: 5px; height: 10px;">
                                <div style="width: <%= surveyStats.rejected %>%; background: var(--danger); height: 100%; border-radius: 5px;"></div>
                            </div>
                        </div>
                        <div>
                            <div style="display: flex; justify-content: space-between; margin-bottom: 0.25rem;">
                                <span>في الانتظار (Waiting)</span>
                                <strong><%= surveyStats.waiting %>%</strong>
                            </div>
                            <div style="width: 100%; background: var(--bg-body); border-radius: 5px; height: 10px;">
                                <div style="width: <%= surveyStats.waiting %>%; background: var(--warning); height: 100%; border-radius: 5px;"></div>
                            </div>
                        </div>
                    </div>
                <% } else { %>
                    <p class="text-muted">لا توجد بيانات كافية بعد.</p>
                <% } %>
            </div>
        </div>
    </div>

