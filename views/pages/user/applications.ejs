<!-- User Navbar -->
<%- include('../../partials/user-sidebar', { path: '/user/my-applications' }) %>

<!-- Main Content -->
<div>
        <h2 style="margin-bottom: 2rem;">سجل التقديمات 📄</h2>

        <!-- Pending Surveys Banner -->
        <% if (locals.pendingSurveys && pendingSurveys > 0) { %>
            <div style="background: var(--danger-bg); border: 1px solid #fecaca; border-radius: var(--radius); padding: 1.5rem; margin-bottom: 2rem; display: flex; align-items: center; justify-content: space-between;">
                <div>
                    <h3 style="color: var(--danger); margin-bottom: 0.5rem;">⚠️ استبيانات التوظيف المعلقة</h3>
                    <p style="margin: 0; color: var(--text-secondary);">يوجد <%= pendingSurveys %> وظيفة مرت 15 يوماً على تقديمك لها. يرجى إخبارنا بنتيجة التقديم لمساعدتنا.</p>
                </div>
            </div>
        <% } %>

        <div style="background: white; border: 1px solid var(--border); border-radius: var(--radius); padding: 1.5rem; box-shadow: var(--shadow-sm);">
            <div style="margin-bottom: 1.5rem; border-bottom: 1px solid var(--border); padding-bottom: 1rem;">
                <h3 style="margin: 0;">كل الوظائف التي قدمت عليها (<%= applications ? applications.length : 0 %>)</h3>
            </div>

            <% if (locals.applications && applications.length > 0) { %>
                <div style="display: flex; flex-direction: column; gap: 1rem;">
                    <% applications.forEach(app => { %>
                        <div style="border: 1px solid var(--border); border-radius: var(--radius-sm); padding: 1.5rem; display: flex; flex-wrap: wrap; justify-content: space-between; align-items: center; gap: 1rem;">
                            <div style="flex: 1; min-width: 250px;">
                                <h4 style="margin-bottom: 0.5rem; font-size: 1.25rem;">
                                    <a href="/jobs/<%= app.job.slug %>"><%= app.job.title %></a>
                                </h4>
                                <div style="color: var(--text-secondary); font-size: 0.95rem; margin-bottom: 0.5rem;">
                                    🏢 <strong><%= app.job.company_name %></strong>
                                </div>
                                <div style="color: var(--text-muted); font-size: 0.85rem;">
                                    تاريخ التقديم: <%= new Date(app.createdAt).toLocaleDateString('ar-EG', { year: 'numeric', month: 'long', day: 'numeric' }) %>
                                </div>
                            </div>
                            
                            <div style="display: flex; flex-direction: column; align-items: flex-end; gap: 1rem;">
                                <% if (app.EmploymentOutcome) { %>
                                    <span class="badge badge-success" style="font-size: 0.9rem; padding: 0.4rem 0.8rem;">استبيان مكتمل ✅</span>
                                    <small style="color: var(--text-muted);">النتيجة: 
                                        <% if (app.EmploymentOutcome.outcome === 'hired') { %>تم التعيين
                                        <% } else if (app.EmploymentOutcome.outcome === 'rejected') { %>مرفوض
                                        <% } else if (app.EmploymentOutcome.outcome === 'waiting') { %>في الانتظار
                                        <% } else { %>لا يوجد تواصل<% } %>
                                    </small>
                                <% } else { %>
                                    <% 
                                        const daysSince = Math.floor((new Date() - new Date(app.createdAt)) / (1000 * 60 * 60 * 24)); 
                                        if (daysSince >= 15) { 
                                    %>
                                        <div style="text-align: left;">
                                            <span class="badge badge-danger" style="margin-bottom: 0.5rem; display: inline-block;">مطلوب ردك ⚠️</span><br>
                                            <a href="/user/survey/<%= app.id %>" class="btn btn-danger" style="padding: 0.4rem 1rem;">إجراء الاستبيان الآن</a>
                                        </div>
                                    <% } else { %>
                                        <div style="text-align: left;">
                                            <div style="background: var(--bg-body); padding: 0.75rem 1rem; border-radius: var(--radius-sm); border: 1px solid var(--border); margin-bottom: 0.5rem; min-width: 180px;">
                                                <div style="font-size: 0.9rem; font-weight: 800; color: var(--primary); margin-bottom: 0.5rem; text-align: right;">تواصل مع صاحب العمل:</div>
                                                <div style="font-size: 0.95rem; font-weight: 700;" dir="ltr">
                                                    <% if (app.job.contact_phone) { %>
                                                        <div style="display: flex; align-items: center; justify-content: flex-end; gap: 0.5rem;">
                                                            <a href="tel:<%= app.job.contact_phone %>" style="text-decoration: underline; color: var(--text-primary);"><%= app.job.contact_phone %></a> 📞
                                                        </div>
                                                    <% } %>
                                                    <% if (app.job.contact_whatsapp) { %>
                                                        <div style="display: flex; align-items: center; justify-content: flex-end; gap: 0.5rem; margin-top: 0.25rem;">
                                                            <a href="https://wa.me/2<%= app.job.contact_whatsapp %>" target="_blank" style="color: #25D366; text-decoration: underline;"><%= app.job.contact_whatsapp %></a> 💬
                                                        </div>
                                                    <% } %>
                                                    <% if (app.job.contact_info && !app.job.contact_phone) { %>
                                                        <div style="display: flex; align-items: center; justify-content: flex-end; gap: 0.5rem; margin-top: 0.25rem;">
                                                            <a href="tel:<%= app.job.contact_info %>" style="text-decoration: underline; color: var(--text-primary);"><%= app.job.contact_info %></a> 📞
                                                        </div>
                                                    <% } %>
                                                    <% if (!app.job.contact_phone && !app.job.contact_whatsapp && !app.job.contact_info) { %>
                                                        <span style="color: var(--text-muted); font-size: 0.85rem;">بيانات التواصل غير متاحة</span>
                                                    <% } %>
                                                </div>
                                            </div>
                                            <small style="display: block; color: var(--text-muted); text-align: center;">باقي <%= 15 - daysSince %> يوم لاستبيان التوظيف</small>
                                        </div>
                                    <% } %>
                                <% } %>
                            </div>
                        </div>
                    <% }) %>
                </div>
            <% } else { %>
                <div class="text-center py-8">
                    <div style="font-size: 4rem; margin-bottom: 1rem;">📄</div>
                    <p style="font-size: 1.1rem; color: var(--text-secondary);">لم تقم بالتقديم على أي وظيفة حتى الآن.</p>
                    <a href="/jobs" class="btn btn-primary mt-4" style="font-size: 1.1rem; padding: 0.75rem 2rem;">تصفح الوظائف المتاحة</a>
                </div>
            <% } %>
        </div>
    </div>

