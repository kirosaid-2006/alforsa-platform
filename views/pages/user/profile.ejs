<!-- User Navbar -->
<%- include('../../partials/user-sidebar', { path: '/user/profile' }) %>

<!-- Main Content -->
<div>
        <h2 style="margin-bottom: 2rem;">تعديل الملف الشخصي ⚙️</h2>

        <div style="background: white; border: 1px solid var(--border); border-radius: var(--radius); padding: 2rem; box-shadow: var(--shadow-sm);">
            
            <form action="/user/profile" method="POST">
                <h3 class="form-section-title" style="margin-top: 0;">البيانات الأساسية</h3>
                
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">الاسم بالكامل</label>
                        <input type="text" name="full_name" class="form-control" value="<%= user.full_name %>" required>
                    </div>
                    <div class="form-group">
                        <label class="form-label">البريد الإلكتروني</label>
                        <input type="email" name="email" class="form-control" value="<%= user.email || '' %>">
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">رقم الهاتف (للاتصال)</label>
                        <input type="text" name="phone" class="form-control" value="<%= user.phone %>" required minlength="11" maxlength="12">
                    </div>
                    <div class="form-group">
                        <label class="form-label">رقم الواتساب</label>
                        <input type="text" name="whatsapp_phone" class="form-control" value="<%= user.whatsapp_phone %>" required minlength="11" maxlength="12">
                    </div>
                </div>

                <h3 class="form-section-title">العنوان والموقع</h3>
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">المحافظة</label>
                        <select name="governorate_id" class="form-control" required>
                            <% if (locals.governorates) { %>
                                <% governorates.forEach(gov => { %>
                                    <option value="<%= gov.id %>" <%= user.governorate_id === gov.id ? 'selected' : '' %>><%= gov.name %></option>
                                <% }) %>
                            <% } %>
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">المدينة / المنطقة</label>
                        <input type="text" name="city" class="form-control" value="<%= user.city %>" required>
                    </div>
                </div>

                <h3 class="form-section-title">البيانات المهنية</h3>
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">المؤهل الدراسي</label>
                        <select name="qualification" class="form-control" required>
                            <option value="none" <%= user.qualification === 'none' ? 'selected' : '' %>>بدون مؤهل / محو أمية</option>
                            <option value="diploma" <%= user.qualification === 'diploma' ? 'selected' : '' %>>دبلوم / مؤهل متوسط</option>
                            <option value="institute" <%= user.qualification === 'institute' ? 'selected' : '' %>>معهد / مؤهل فوق متوسط</option>
                            <option value="bachelors" <%= user.qualification === 'bachelors' ? 'selected' : '' %>>بكالوريوس / ليسانس</option>
                            <option value="masters" <%= user.qualification === 'masters' ? 'selected' : '' %>>ماجستير</option>
                            <option value="phd" <%= user.qualification === 'phd' ? 'selected' : '' %>>دكتوراه</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">الوظيفة الحالية أو المستهدفة</label>
                        <input type="text" name="last_job_title" class="form-control" value="<%= user.last_job_title || '' %>">
                    </div>
                </div>

                <div class="mt-8 pt-4" style="border-top: 1px solid var(--border);">
                    <button type="submit" class="btn btn-primary" style="padding: 0.75rem 2.5rem; font-size: 1.1rem;">حفظ التعديلات</button>
                    <a href="/user/dashboard" class="btn btn-outline" style="margin-right: 1rem;">إلغاء</a>
                </div>
            </form>

        </div>
    </div>

