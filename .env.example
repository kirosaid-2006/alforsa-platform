PORT=3000
NODE_ENV=development
SESSION_SECRET=some-very-secure-secret-key-12345
JWT_SECRET=another-super-secure-jwt-secret-key-67890

# قاعدة البيانات (SQLite للتطوير، PostgreSQL للإنتاج)
DB_DIALECT=sqlite
DB_STORAGE=./database/wazifanet.sqlite

# إعدادات تليجرام وبوت التوجيه
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_WEBHOOK_SECRET=your-webhook-secret
TELEGRAM_CHANNEL_USERNAME=@your_monitored_channel

# مفاتيح Grok AI
GROK_API_KEY=your-grok-api-key
GROK_MOCK_MODE=true  # تفعيل وضع المحاكاة للتطوير بدون استهلاك الرصيد
